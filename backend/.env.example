PORT=5000
MONGODB_URI=mongodb://localhost:27017/thechemstore

JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

EMAIL_USER=your_gmail@gmail.com
# Generate an app password at https://myaccount.google.com/apppasswords
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=TheChemStore <your_gmail@gmail.com>

CLIENT_URL=http://localhost:5173

# JSearch (RapidAPI) — sign up at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key

# Google Gemini — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Cron schedule (default: 2 AM IST daily). Standard cron syntax.
JOB_SYNC_CRON=0 2 * * *

# Secret to manually trigger sync via POST /api/jobs/sync
SYNC_SECRET=your_sync_secret
